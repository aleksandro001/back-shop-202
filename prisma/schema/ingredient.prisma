model Ingredient {
  id String @id @default(cuid())

  name        String
  defaultUnit Unit?  @default(GRAM) @map("default_unit")

  recipeIngredients RecipeIngredient[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  recipes   Recipe[]

  @@map("ingredients")
}

enum Unit {
  GRAM
  MILLILITER
  PIECE
  TEASPOON
  TABLESPOON
  CLOVES
}
