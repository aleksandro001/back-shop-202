model Ingredient {
  id String @id @default(cuid())

  name    String
  iconUrl String @map("icon_url")
  content String

  recipeIngredients RecipeIngredient[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  recipes   Recipe[]

  @@map("ingredients")
}

enum Unit {
  GRAM
  MILLILITER
  PIECE
  TEASPOON
  TABLESPOON
  CLOVES
}
